<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-beers-table" author="Ashkan Zanjani">
        <createTable tableName="beers">
            <column name="id" type="CHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="002-create-orders-table" author="Ashkan Zanjani">
        <createTable tableName="orders">
            <column name="id" type="CHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="total_amount" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="payment_method" type="VARCHAR(50)"/>
            <column name="paid_at" type="DATETIME(6)"/>
            <column name="created_at" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="003-create-order-items-table" author="Ashkan Zanjani">
        <createTable tableName="order_items">
            <column name="id" type="CHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_id" type="CHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="beer_id" type="CHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="unit_price" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="total_price" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="order_items"
            baseColumnNames="order_id"
            referencedTableName="orders"
            referencedColumnNames="id"
            constraintName="fk_order_items_order"/>

        <addForeignKeyConstraint
            baseTableName="order_items"
            baseColumnNames="beer_id"
            referencedTableName="beers"
            referencedColumnNames="id"
            constraintName="fk_order_items_beer"/>
    </changeSet>

    <changeSet id="003-seed-beers" author="Ashkan Zanjani">

        <insert tableName="beers">
            <column name="id" value="11111111-1111-1111-1111-111111111111"/>
            <column name="name" value="Heineken"/>
            <column name="price" valueNumeric="3.50"/>
            <column name="created_at" valueDate="2026-01-01T00:00:00"/>
        </insert>

        <insert tableName="beers">
            <column name="id" value="22222222-2222-2222-2222-222222222222"/>
            <column name="name" value="Corona"/>
            <column name="price" valueNumeric="4.00"/>
            <column name="created_at" valueDate="2026-01-01T00:00:00"/>
        </insert>

        <insert tableName="beers">
            <column name="id" value="33333333-3333-3333-3333-333333333333"/>
            <column name="name" value="Amstel"/>
            <column name="price" valueNumeric="6.00"/>
            <column name="created_at" valueDate="2026-01-01T00:00:00"/>
        </insert>

        <insert tableName="beers">
            <column name="id" value="44444444-4444-4444-4444-444444444444"/>
            <column name="name" value="Bavaria"/>
            <column name="price" valueNumeric="3.00"/>
            <column name="created_at" valueDate="2026-01-01T00:00:00"/>
        </insert>

    </changeSet>
</databaseChangeLog>